import Foundation


class Aluno{
    
    var nome: String = ""
    var nota1: Double = 0.0
    var nota2: Double = 0.0
    
    func media(nota1: Double, nota2: Double) -> Double{
        
        return(nota1 + nota2)/2
    }
    
    func status(nota1: Double, nota2: Double) -> String{
        
        if (nota1 + nota2) / 2 >= 7.0{
            return "Aprovado"
        }else{
            return"Reprovado"
        }
    }
    
    func buscarStatus(nome: String, nota1: Double, nota2: Double){
        print("O aluno \(nome) teve uma média de \(media(nota1: nota1, nota2: nota2)) e está \(status(nota1: nota1, nota2: nota2)).")
        
    }
    
}

var aluno1 = Aluno()

print("----------------------")
print("Digite o nome do aluno: ")
aluno1.nome = readLine() ?? ""
print("Digite a primeira nota: ")
aluno1.nota1 = Double(readLine() ?? "0.0") ?? 0.0
print("Digite a segunda nota: ")
aluno1.nota2 = Double(readLine() ?? "0.0") ?? 0.0
print("----------------------")

aluno1.buscarStatus(nome: aluno1.nome, nota1: aluno1.nota1, nota2: aluno1.nota2)




